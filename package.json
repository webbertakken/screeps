{
  "name": "screeps",
  "version": "3.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "push-main": "rollup -c --environment DEST:main",
    "push-dev": "rollup -c --environment DEST:develop",
    "watch-main": "rollup -cw --environment DEST:main",
    "watch-dev": "rollup -cw --environment DEST:develop",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "test:watch": "vitest",
    "test:integration": "echo 'See docs/in-depth/testing.md for instructions on enabling integration tests'",
    "coverage": "vitest run --coverage",
    "lint": "yarn oxlint --report-unused-disable-directives",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "setup:hooks": "node scripts/ensure-husky.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webbertakken/screeps.git"
  },
  "author": "Webber",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/webbertakken/screeps/issues"
  },
  "homepage": "https://github.com/webbertakken/screeps#readme",
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@types/lodash": "4.17.16",
    "@types/node": "^22.15.17",
    "@types/screeps": "^3.3.8",
    "@typescript/native-preview": "^7.0.0-dev.20260505.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "9",
    "lint-staged": "^16.4.0",
    "lodash": "^4.17.21",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "rollup": "^4.40.2",
    "rollup-plugin-clear": "^2.0.7",
    "rollup-plugin-screeps": "^1.0.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "typescript": "^5.8.3",
    "vite": "^7",
    "vitest": "^4"
  },
  "dependencies": {
    "source-map": "~0.6.1"
  },
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "unrs-resolver": {
      "built": true
    }
  }
}
