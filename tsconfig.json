{
  "compilerOptions": {
    "module": "esnext",
    "lib": ["es2022"],
    "target": "es2022",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "paths": {
      "*": ["./src/*"]
    },
    "sourceMap": true,
    "strict": true,
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["@types/screeps", "@types/node", "@types/lodash"]
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
